# Production environment variables for Railway + managed cloud backends.
# Copy to .env.production.local for local seeding against production:
#   cp .env.production.example .env.production.local
# Then run: npm run seed
#
# Set the same values in Railway → Service → Variables (never commit secrets).

NODE_ENV=production

# ── LLM ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=
JINA_API_KEY=
LLM_PROVIDER=groq

# ── Qdrant Cloud (https://cloud.qdrant.io) ───────────────────────────────────
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io
QDRANT_API_KEY=

# ── Neo4j Aura (https://neo4j.com/cloud/aura/) ────────────────────────────────
NEO4J_URI=neo4j+s://YOUR-INSTANCE.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ── Upstash Redis (https://upstash.com) ───────────────────────────────────────
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR_HOST.upstash.io:6379

# ── Optional ──────────────────────────────────────────────────────────────────
# HOSTED_BASE_URL=
# HOSTED_API_KEY=
# HOSTED_MODEL=
