# ── LLM — Groq (required when LLM_PROVIDER=groq, which is the default) ──────
GROQ_API_KEY=your_groq_api_key_here

# ── Embeddings — Jina AI (required; falls back to Ollama if unset) ───────────
JINA_API_KEY=your_jina_api_key_here

# ── Provider selection ────────────────────────────────────────────────────────
# groq (default) | ollama | hosted
LLM_PROVIDER=groq

# ── Vector store ──────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── Graph database ────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ── Cache / job queue ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Optional: Ollama on-prem deployment ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Optional: any OpenAI-compatible hosted endpoint ──────────────────────────
HOSTED_BASE_URL=
HOSTED_API_KEY=
HOSTED_MODEL=
